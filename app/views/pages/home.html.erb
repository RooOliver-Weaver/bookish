<div class="hero">
  <div class="container">
    <div class="hero-content">
      <h1>📚 Your Personal Book Tracker</h1>
      <p class="lead">
        Organize your reading, create custom book lists, and never lose track of a title again.
      </p>
      <div class="cta-buttons">
        <%= link_to "Explore Books", books_path, class: "btn btn-primary btn-lg" %>
        <%= link_to "Sign Up for Free", new_user_registration_path, class: "btn btn-accent btn-lg" %>
      </div>
    </div>
  </div>
</div>

<%= render "shared/bookshelf" %>

<!-- Featured Books Section -->
<div class="featured-books">
  <div class="container">
    <h2 class="section-title">🌟 Featured Reads</h2>
    <p class="section-subtitle">Discover popular books and hidden gems.</p>
    <div class="book-grid">
      <% @books.each do |book| %>
        <article class="book-card">
          <div class="book-image-container">
            <%= image_tag book.cover_url.presence,
                          alt: book.title,
                          class: "book-image" %>
          </div>
          <div class="book-info">
            <h3><%= book.title %></h3>
            <p class="author">by <%= book.author.name %></p>
            <%= link_to "View Book", book_path(book), class: "btn btn-secondary" %>
          </div>
        </article>
      <% end %>
    </div>
  </div>
</div>

<!-- Call to Action Section -->
<div class="cta-section">
  <div class="container">
    <h2>📖 Start Your Reading Journey Today</h2>
    <p>Sign up to create book lists, track your progress, and organize your reading goals effortlessly.</p>
    <%= link_to "Join Now", new_user_registration_path, class: "btn btn-primary btn-lg" %>
  </div>
</div>
